#!/bin/bash

# Add the named packages to the system. On Fedora, AUR doesn't exist,
# so we try dnf (with name mapping) and COPR as fallbacks.

source "$HOME/.local/share/omarchy-fedora/pkg-helpers.sh"

translate_pkgs "$@"

# Warn about skipped packages
for pkg in "${SKIPPED_PKGS[@]}"; do
  echo -e "\033[33mWarning: '$pkg' has no Fedora equivalent (AUR package, skipped)\033[0m" >&2
done

# Install dnf packages (some AUR packages have regular Fedora equivalents)
if [[ ${#DNF_PKGS[@]} -gt 0 ]]; then
  missing=()
  for pkg in "${DNF_PKGS[@]}"; do
    if ! is_pkg_installed "$pkg"; then
      missing+=("$pkg")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    sudo dnf install -y "${missing[@]}" || exit 1
  fi
fi

# Install flatpak packages
for fpak in "${FLATPAK_PKGS[@]}"; do
  if ! flatpak info "$fpak" &>/dev/null; then
    flatpak install -y flathub "$fpak" || exit 1
  fi
done

# If everything was skipped, exit with error
if [[ ${#DNF_PKGS[@]} -eq 0 && ${#FLATPAK_PKGS[@]} -eq 0 && ${#SKIPPED_PKGS[@]} -gt 0 ]]; then
  echo -e "\033[31mNo installable packages found for Fedora.\033[0m" >&2
  exit 1
fi

exit 0

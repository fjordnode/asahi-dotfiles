#!/bin/bash

# Walker launcher -- routes all calls through walker.
# Backup of fzf-in-kitty theme picker: omarchy-launch-walker.fzf-backup

export OMARCHY_PATH="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
export PATH="$HOME/.local/bin:$OMARCHY_PATH/bin:$PATH"

if [[ "$*" == *"--dmenu"* ]]; then
  # Route dmenu calls through walker
  args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dmenu) args+=(--dmenu) ;;
      -p) args+=(--placeholder "$2"); shift ;;
      -c) args+=(-c "$2"); shift ;;
      --width) args+=(--width "$2"); shift ;;
      --minheight) args+=(--minheight "$2"); shift ;;
      --maxheight) args+=(--maxheight "$2"); shift ;;
      -m) args+=(-m "$2"); shift ;;
      *) ;;
    esac
    shift
  done
  exec walker "${args[@]}"

else
  # Pass all args through to walker (app launcher, clipboard, symbols, etc.)
  exec walker "$@"
fi

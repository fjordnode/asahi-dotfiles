[main]
font=JetBrainsMono Nerd Font:size=14
prompt="  "
width=45
lines=12
tabs=4
horizontal-pad=20
vertical-pad=12
inner-pad=8
layer=overlay
exit-on-keyboard-focus-loss=yes

[colors]
background={{ background_strip }}ee
text={{ foreground_strip }}ff
match={{ accent_strip }}ff
selection={{ color0_strip }}ff
selection-text={{ accent_strip }}ff
selection-match={{ accent_strip }}ff
border={{ accent_strip }}ff
prompt={{ accent_strip }}ff

[border]
width=2
radius=8

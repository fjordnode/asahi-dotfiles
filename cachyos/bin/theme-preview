#!/bin/bash
# Lightweight theme preview — swaps wallpaper + terminal colors without full apply
# Used by theme-pick for live preview as you browse themes

set -eu

THEME_NAME="${1:-}"
[[ -z "$THEME_NAME" ]] && exit 1

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.local/share/dotfiles}"
THEMES_DIR="$DOTFILES_DIR/themes"
USER_THEMES_DIR="$HOME/.config/themes/custom"

# Find theme directory
THEME_DIR=""
[[ -d "$USER_THEMES_DIR/$THEME_NAME" ]] && THEME_DIR="$USER_THEMES_DIR/$THEME_NAME"
[[ -z "$THEME_DIR" && -d "$THEMES_DIR/$THEME_NAME" ]] && THEME_DIR="$THEMES_DIR/$THEME_NAME"
[[ -z "$THEME_DIR" ]] && { echo "Theme not found: $THEME_NAME"; exit 1; }

# Show theme info in fzf preview pane
echo "Theme: $THEME_NAME"
echo ""
if [[ -f "$THEME_DIR/colors.toml" ]]; then
  while IFS='=' read -r key value; do
    key="${key//[\"\' ]/}"
    [[ $key && $key != \#* ]] || continue
    value="${value#*[\"\']}"
    value="${value%%[\"\']*}"
    # Print colored block using ANSI escape
    local_hex="${value#\#}"
    r=$((16#${local_hex:0:2})) g=$((16#${local_hex:2:2})) b=$((16#${local_hex:4:2}))
    printf '\033[48;2;%d;%d;%dm  \033[0m %s = %s\n' "$r" "$g" "$b" "$key" "$value"
  done <"$THEME_DIR/colors.toml"
fi

# Count backgrounds
bg_count=$(find "$THEME_DIR/backgrounds" -maxdepth 1 -type f 2>/dev/null | wc -l)
echo ""
echo "Backgrounds: $bg_count"

# Swap wallpaper (non-blocking)
BG=$(find "$THEME_DIR/backgrounds" -maxdepth 1 -type f 2>/dev/null | sort | head -1)
[[ -n "$BG" ]] && swww img "$BG" --transition-type fade --transition-duration 0.3 2>/dev/null &

# Preview kitty colors
COLORS="$THEME_DIR/colors.toml"
TPL="$DOTFILES_DIR/templates/kitty.conf.tpl"
if [[ -f "$COLORS" && -f "$TPL" ]] && pgrep -x kitty >/dev/null; then
  tmpfile=$(mktemp)
  sed_args=()
  while IFS='=' read -r key value; do
    key="${key//[\"\' ]/}"
    [[ $key && $key != \#* ]] || continue
    value="${value#*[\"\']}"
    value="${value%%[\"\']*}"
    sed_args+=(-e "s|{{ $key }}|$value|g")
  done <"$COLORS"
  sed "${sed_args[@]}" "$TPL" >"$tmpfile"
  for sock in /tmp/kitty-*; do
    kitty @ --to "unix:$sock" set-colors --all "$tmpfile" 2>/dev/null || true
  done
  rm -f "$tmpfile"
fi

wait 2>/dev/null || true

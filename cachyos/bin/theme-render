#!/bin/bash
# Template rendering engine — reads colors.toml and applies to *.tpl templates
# Generates themed config files for waybar, kitty, hyprland, mako, etc.

set -eu

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.local/share/dotfiles}"
TEMPLATES_DIR="$DOTFILES_DIR/templates"
USER_TEMPLATES_DIR="$HOME/.config/themes/templates"
THEME_DIR="$HOME/.config/themes/current"
COLORS_FILE="$THEME_DIR/colors.toml"

# Convert hex color to decimal RGB (e.g., "#1e1e2e" -> "30,30,46")
hex_to_rgb() {
  local hex="${1#\#}"
  printf "%d,%d,%d" "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

if [[ ! -f $COLORS_FILE ]]; then
  echo "No colors.toml found in $THEME_DIR" >&2
  exit 1
fi

sed_script=$(mktemp)
trap 'rm -f "$sed_script"' EXIT

while IFS='=' read -r key value; do
  key="${key//[\"\' ]/}"
  [[ $key && $key != \#* ]] || continue
  value="${value#*[\"\']}"
  value="${value%%[\"\']*}"

  printf 's|{{ %s }}|%s|g\n' "$key" "$value"
  printf 's|{{ %s_strip }}|%s|g\n' "$key" "${value#\#}"
  if [[ $value =~ ^# ]]; then
    rgb=$(hex_to_rgb "$value")
    echo "s|{{ ${key}_rgb }}|${rgb}|g"
  fi
done <"$COLORS_FILE" >"$sed_script"

shopt -s nullglob

# Process user templates first (override), then built-in templates
for tpl in "$USER_TEMPLATES_DIR"/*.tpl "$TEMPLATES_DIR"/*.tpl; do
  [[ -f $tpl ]] || continue
  filename=$(basename "$tpl" .tpl)
  output_path="$THEME_DIR/$filename"

  # Don't overwrite configs already in the theme directory
  if [[ ! -f $output_path ]]; then
    sed -f "$sed_script" "$tpl" >"$output_path"
  fi
done

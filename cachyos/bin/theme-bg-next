#!/bin/bash
# Cycle through wallpapers for the current theme

set -eu

THEME_NAME=$(cat "$HOME/.config/themes/current.name" 2>/dev/null || echo "")
THEME_BG_DIR="$HOME/.config/themes/current/backgrounds"
USER_BG_DIR="$HOME/.config/themes/backgrounds/$THEME_NAME"
LINK="$HOME/.config/themes/current/background"

mapfile -d '' -t BACKGROUNDS < <(find -L "$USER_BG_DIR" "$THEME_BG_DIR" -maxdepth 1 -type f -print0 2>/dev/null | sort -z)
TOTAL=${#BACKGROUNDS[@]}

if (( TOTAL == 0 )); then
  # No theme backgrounds — try global wallpaper directory
  mapfile -d '' -t BACKGROUNDS < <(find -L "$HOME/Pictures/wallpapers" -maxdepth 1 -type f -print0 2>/dev/null | sort -z)
  TOTAL=${#BACKGROUNDS[@]}
fi

if (( TOTAL == 0 )); then
  notify-send "No wallpapers found" -t 2000 2>/dev/null || true
  exit 0
fi

# Find current index
CURRENT=""
[[ -L $LINK ]] && CURRENT=$(readlink "$LINK")

INDEX=-1
for i in "${!BACKGROUNDS[@]}"; do
  if [[ ${BACKGROUNDS[$i]} == "$CURRENT" ]]; then
    INDEX=$i
    break
  fi
done

if (( INDEX == -1 )); then
  NEW="${BACKGROUNDS[0]}"
else
  NEXT=$(((INDEX + 1) % TOTAL))
  NEW="${BACKGROUNDS[$NEXT]}"
fi

theme-bg-set "$NEW"

#!/bin/bash
# Watches clipboard changes and records the source app in metadata.
# Runs alongside cliphist — call via: wl-paste --watch yoink-watcher

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/yoink"
META="$DATA_DIR/metadata.json"
mkdir -p "$DATA_DIR"
[ -f "$META" ] || echo '{"entries":{}}' > "$META"

# Get source window class — skip our own TUI to avoid overwriting real sources
source_class=$(hyprctl activewindow -j 2>/dev/null | jq -r '.class // ""')
[ -z "$source_class" ] && exit 0
[ "$source_class" = "yoink" ] && exit 0

# Wait for cliphist to store the entry (retry up to 500ms)
entry_id=""
for _ in 1 2 3 4 5; do
  entry_id=$(cliphist list | head -1 | cut -f1)
  [ -n "$entry_id" ] && break
  sleep 0.1
done
[ -z "$entry_id" ] && exit 0

# ISO 8601 timestamp matching Go's time.RFC3339Nano
ts=$(date -u +"%Y-%m-%dT%H:%M:%S.%NZ")

# Update metadata — set source only if not already set, preserve pinned
tmp="$META.tmp.$$"
jq --arg id "$entry_id" --arg src "$source_class" --arg ts "$ts" \
  '.entries[$id].source //= $src | .entries[$id].pinned //= false | .entries[$id].timestamp //= $ts' \
  "$META" > "$tmp" 2>/dev/null && mv "$tmp" "$META"

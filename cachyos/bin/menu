#!/bin/bash
# System menu ‚ÄĒ walker/fuzzel based, replaces omarchy-menu

set -eu

BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"
  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  shift 2

  if command -v fuzzel >/dev/null 2>&1; then
    echo -e "$options" | fuzzel --dmenu --prompt="$prompt‚Ä¶ " --width=28 "$@"
  elif command -v walker >/dev/null 2>&1; then
    echo -e "$options" | walker --dmenu --placeholder "$prompt‚Ä¶" --width 295 "$@"
  else
    echo -e "$options" | fzf --prompt="$prompt > " "$@"
  fi
}

terminal() {
  kitty "$@"
}

float_terminal() {
  kitty --app-id tui.menu -e bash -c "$*"
}

open_in_editor() {
  notify-send "Editing config file" "$1" 2>/dev/null || true
  kitty -e ${EDITOR:-nvim} "$1"
}

install() {
  float_terminal "echo 'Installing $1...'; yay -S --needed $2 && echo 'Done!' && read -n1"
}

install_and_launch() {
  float_terminal "echo 'Installing $1...'; yay -S --needed $2 && echo 'Done!' && read -n1; setsid gtk-launch $3 2>/dev/null &"
}

# ‚ĒÄ‚ĒÄ Learn ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_learn_menu() {
  case $(menu "Learn" "  Keybindings\n  Hyprland\nůį£á  Arch\n  Neovim\nůĪÜÉ  Bash") in
  *Keybindings*) xdg-open "https://wiki.hyprland.org/Configuring/Binds/" ;;
  *Hyprland*) xdg-open "https://wiki.hypr.land/" ;;
  *Arch*) xdg-open "https://wiki.archlinux.org/title/Main_page" ;;
  *Neovim*) xdg-open "https://www.lazyvim.org/keymaps" ;;
  *Bash*) xdg-open "https://devhints.io/bash" ;;
  *) back_to show_main_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Trigger ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_trigger_menu() {
  case $(menu "Trigger" "  Capture\n  Share\nůįĒé  Toggle\n  Hardware") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) back_to show_main_menu ;;
  esac
}

show_capture_menu() {
  case $(menu "Capture" "  Screenshot\n  Screenrecord\nůįÉČ  Color") in
  *Screenshot*) grim -g "$(slurp)" - | satty -f - ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_screenrecord_menu() {
  # Stop existing recording if active
  if pkill -SIGINT wf-recorder 2>/dev/null; then
    notify-send "Recording saved" 2>/dev/null || true
    exit 0
  fi

  local outfile="$HOME/Videos/recording-$(date +%Y%m%d-%H%M%S).mp4"

  case $(menu "Screenrecord" "  With no audio\n  With desktop audio\n  With desktop + microphone audio") in
  *"With no audio"*) wf-recorder -g "$(slurp)" -f "$outfile" &disown ;;
  *"With desktop audio"*) wf-recorder -g "$(slurp)" --audio -f "$outfile" &disown ;;
  *"With desktop + microphone"*) wf-recorder -g "$(slurp)" --audio -f "$outfile" &disown ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "  Clipboard\n  File\n  Folder") in
  *Clipboard*) wl-paste | wl-copy ;;
  *File*) xdg-open "$(zenity --file-selection 2>/dev/null)" 2>/dev/null ;;
  *Folder*) dolphin "$(pwd)" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "ůĪĄĄ  Screensaver\nůįĒé  Nightlight\nůĪęĖ  Idle Lock\nůįćú  Top Bar") in
  *Screensaver*) hyprlock ;;
  *Nightlight*) pkill hyprsunset 2>/dev/null && notify-send "Nightlight off" || { hyprsunset -t 4500 &disown; notify-send "Nightlight on"; } ;;
  *Idle*) pkill hypridle 2>/dev/null && notify-send "Idle lock disabled" || { hypridle &disown; notify-send "Idle lock enabled"; } ;;
  *Bar*) pkill -SIGUSR1 waybar ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  case $(menu "Hardware" "  Audio\nůĪöĺ  Wi-Fi\nůįāĮ  Bluetooth") in
  *Audio*) float_terminal "systemctl --user restart pipewire pipewire-pulse wireplumber && echo 'PipeWire restarted' && sleep 2" ;;
  *Wi-Fi*) float_terminal "nmcli radio wifi off && sleep 1 && nmcli radio wifi on && echo 'Wi-Fi restarted' && sleep 2" ;;
  *Bluetooth*) float_terminal "sudo systemctl restart bluetooth && echo 'Bluetooth restarted' && sleep 2" ;;
  *) back_to show_trigger_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Style ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_style_menu() {
  case $(menu "Style" "ůįłĆ  Theme\nůįÖí  Background\nůįēÜ  Hyprland\nůįčĹ  About") in
  *Theme*) theme-pick ;;
  *Background*) theme-bg-next ;;
  *Hyprland*) open_in_editor ~/.config/hypr/looknfeel.conf ;;
  *About*) float_terminal "fastfetch; read -n1" ;;
  *) back_to show_main_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Setup ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_setup_menu() {
  local options="  Audio\n  Wifi\nůįāĮ  Bluetooth\nůĪźč  Power Profile\n  System Sleep\nůįćĻ  Monitors"
  [[ -f ~/.config/hypr/bindings.conf ]] && options="$options\n  Keybindings"
  [[ -f ~/.config/hypr/input.conf ]] && options="$options\n  Input"
  options="$options\n  Security\n  Config"

  case $(menu "Setup" "$options") in
  *Audio*) pavucontrol ;;
  *Wifi*) launch-tui impala ;;
  *Bluetooth*) launch-tui bluetui ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Monitors*) open_in_editor ~/.config/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.config/hypr/bindings.conf ;;
  *Input*) open_in_editor ~/.config/hypr/input.conf ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) back_to show_main_menu ;;
  esac
}

show_setup_power_menu() {
  if ! command -v powerprofilesctl >/dev/null 2>&1; then
    notify-send "power-profiles-daemon not installed"
    return
  fi
  local current
  current=$(powerprofilesctl get)
  local profile
  profile=$(menu "Power Profile" "$(powerprofilesctl list | grep -oP '^\s+\K\S+' | sort -u)" "" "$current") || { back_to show_setup_menu; return; }
  [[ -n $profile ]] && powerprofilesctl set "$profile"
}

show_setup_system_menu() {
  local options=""
  if systemctl is-active --quiet suspend.target 2>/dev/null; then
    options="ůįí≤  Disable Suspend"
  else
    options="ůįí≤  Enable Suspend"
  fi

  case $(menu "System" "$options") in
  *"Disable Suspend"*) sudo systemctl mask suspend.target && notify-send "Suspend disabled" ;;
  *"Enable Suspend"*) sudo systemctl unmask suspend.target && notify-send "Suspend enabled" ;;
  *) back_to show_setup_menu ;;
  esac
}

show_setup_security_menu() {
  case $(menu "Security" "ůįą∑  Fingerprint\n  Fido2") in
  *Fingerprint*) float_terminal "fprintd-enroll; read -n1" ;;
  *Fido2*) float_terminal "echo 'Use systemd-cryptenroll for FIDO2 setup'; read -n1" ;;
  *) back_to show_setup_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Config" "  Hyprland\n  Hypridle\n  Hyprlock\n  SwayOSD\nůįĆß  Walker\nůįćú  Waybar\n  Mako") in
  *Hyprland*) open_in_editor ~/.config/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *SwayOSD*) open_in_editor ~/.config/swayosd/config.toml ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc ;;
  *Mako*) open_in_editor ~/.config/mako/config ;;
  *) back_to show_setup_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Install ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_install_menu() {
  case $(menu "Install" "ůį£á  Package\nůį£á  AUR\n  TUI\n  Service\n  Style\nůįĶģ  Development\n  Editor\n  Terminal\nůĪö§  AI\n  Gaming") in
  *"AUR"*) terminal yay ;;
  *Package*) terminal bash -c "yay -Slq | fzf --multi --preview 'yay -Si {}' | xargs -ro yay -S --needed" ;;
  *TUI*) terminal bash -c "yay -Slq | fzf --multi --preview 'yay -Si {}' | xargs -ro yay -S --needed" ;;
  *Service*) show_install_service_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Gaming*) show_install_gaming_menu ;;
  *) back_to show_main_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "  Dropbox\n  Tailscale\nůĪáĪ  NordVPN\nůįüĶ  Bitwarden") in
  *Dropbox*) install "Dropbox" "dropbox" ;;
  *Tailscale*) install "Tailscale" "tailscale" ;;
  *NordVPN*) install "NordVPN" "nordvpn-bin" ;;
  *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
  *) back_to show_install_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "ůįłĆ  Theme\n  Background\n  Font") in
  *Theme*) theme-pick ;;
  *Background*) theme-bg-next ;;
  *Font*) show_install_font_menu ;;
  *) back_to show_install_menu ;;
  esac
}


  case $(menu "Install" "  Cascadia Mono\n  Meslo LG Mono\n  Fira Code\n  Victor Mono\n  Bitstream Vera Mono\n  Iosevka") in
  *Cascadia*) install "Cascadia Mono" "ttf-cascadia-mono-nerd" ;;
  *Meslo*) install "Meslo LG Mono" "ttf-meslo-nerd" ;;
  *Fira*) install "Fira Code" "ttf-firacode-nerd" ;;
  *Victor*) install "Victor Mono" "ttf-victor-mono-nerd" ;;
  *Bitstream*) install "Bitstream Vera Mono" "ttf-bitstream-vera-mono-nerd" ;;
  *Iosevka*) install "Iosevka" "ttf-iosevka-nerd" ;;
  *) back_to show_install_style_menu ;;
  esac
}


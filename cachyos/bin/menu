  case $(menu "Install" "  Alacritty\n  Ghostty\n  Kitty\n  WezTerm\n  Foot") in
  *Alacritty*) install "Alacritty" "alacritty" ;;
  *Ghostty*) install "Ghostty" "ghostty" ;;
  *Kitty*) install "Kitty" "kitty" ;;
  *WezTerm*) install "WezTerm" "wezterm" ;;
  *Foot*) install "Foot" "foot" ;;
  *) back_to show_install_menu ;;
  esac
}

show_install_ai_menu() {
  local ollama_pkg
  ollama_pkg=$( (command -v nvidia-smi &>/dev/null && echo ollama-cuda) || (command -v rocminfo &>/dev/null && echo ollama-rocm) || echo ollama )

  case $(menu "Install" "ůĪö§  Claude Code\nůĪö§  Codex\nůĪö§  Gemini CLI\nůĪö§  LM Studio\nůĪö§  Ollama") in
  *Claude*) install "Claude Code" "claude-code" ;;
  *Codex*) install "Codex" "openai-codex" ;;
  *Gemini*) install "Gemini CLI" "gemini-cli" ;;
  *Studio*) install "LM Studio" "lmstudio" ;;
  *Ollama*) install "Ollama" "$ollama_pkg" ;;
  *) back_to show_install_menu ;;
  esac
}

show_install_gaming_menu() {
  case $(menu "Install" "  Steam\nůįĘĻ  GeForce NOW\n  RetroArch\nůįć≥  Minecraft\nůįĖļ  Xbox Controller") in
  *Steam*) install "Steam" "steam" ;;
  *GeForce*) install "GeForce NOW" "geforcenow-electron" ;;
  *RetroArch*) install_and_launch "RetroArch" "retroarch retroarch-assets-xmb libretro" "com.libretro.RetroArch" ;;
  *Minecraft*) install_and_launch "Minecraft" "minecraft-launcher" "minecraft-launcher" ;;
  *Xbox*) install "Xbox Controller" "xpadneo-dkms xone-dkms" ;;
  *) back_to show_install_menu ;;
  esac
}


  *Rust*) float_terminal "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh" ;;
  *Java*) install "Java" "jdk-openjdk" ;;
  *NET*) install ".NET" "dotnet-sdk" ;;
  *OCaml*) install "OCaml" "ocaml opam" ;;
  *Clojure*) install "Clojure" "clojure" ;;
  *Scala*) install "Scala" "scala sbt" ;;
  *) back_to show_install_menu ;;
  esac
}

show_install_javascript_menu() {
  case $(menu "Install" "  Node.js\n  Bun\n  Deno") in
  *Node*) install "Node.js" "nodejs npm" ;;
  *Bun*) float_terminal "curl -fsSL https://bun.sh/install | bash" ;;
  *Deno*) install "Deno" "deno" ;;
  *) back_to show_install_development_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Remove ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_remove_menu() {
  case $(menu "Remove" "ůį£á  Package\nůįĶģ  Development\nůįą∑  Fingerprint\n  Fido2") in
  *Package*) terminal bash -c "yay -Qeq | fzf --multi --preview 'yay -Qi {}' | xargs -ro yay -Rns" ;;
  *Development*) terminal bash -c "yay -Qeq | fzf --multi --preview 'yay -Qi {}' | xargs -ro yay -Rns" ;;
  *Fingerprint*) float_terminal "fprintd-delete \$(whoami); read -n1" ;;
  *Fido2*) float_terminal "echo 'Use systemd-cryptenroll --wipe-slot=fido2'; read -n1" ;;
  *) back_to show_main_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Update ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_update_menu() {
  case $(menu "Update" "  System\n  Config\n  Process\nůįáÖ  Hardware\n  Firmware\n  Password\n  Timezone\n  Time") in
  *System*) float_terminal "yay -Syu; read -n1" ;;
  *Config*) show_setup_config_menu ;;
  *Process*) show_restart_menu ;;
  *Hardware*) show_hardware_menu ;;
  *Firmware*) float_terminal "fwupdmgr refresh && fwupdmgr get-updates && fwupdmgr update; read -n1" ;;
  *Timezone*) float_terminal "sudo timedatectl set-timezone \$(timedatectl list-timezones | fzf); read -n1" ;;
  *Time*) float_terminal "sudo timedatectl set-ntp true && timedatectl status; read -n1" ;;
  *Password*) show_update_password_menu ;;
  *) back_to show_main_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "  Drive Encryption\n  User") in
  *Drive*) float_terminal "echo 'Use cryptsetup to change LUKS password'; read -n1" ;;
  *User*) float_terminal "passwd; read -n1" ;;
  *) back_to show_update_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Restart ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_restart_menu() {
  case $(menu "Restart" "  Hypridle\n  SwayOSD\nůįĆß  Walker\nůįćú  Waybar\n  Mako") in
  *Hypridle*) killall hypridle 2>/dev/null; hypridle &disown ;;
  *SwayOSD*) killall swayosd-server 2>/dev/null; swayosd-server -s ~/.config/themes/current/swayosd.css &disown ;;
  *Walker*) killall walker 2>/dev/null; sleep 0.3; walker --gapplication-service &disown ;;
  *Waybar*) killall waybar 2>/dev/null; sleep 0.3; waybar &disown ;;
  *Mako*) makoctl reload 2>/dev/null ;;
  *) back_to show_update_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ System ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_system_menu() {
  local options="ůĪĄĄ  Screensaver\n  Lock\nůįí≤  Suspend\nůįćÉ  Logout\nůįúČ  Restart\nůįź•  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) hyprlock ;;
  *Lock*) hyprlock ;;
  *Suspend*) systemctl suspend ;;
  *Logout*) hyprctl dispatch exit ;;
  *Restart*) systemctl reboot ;;
  *Shutdown*) systemctl poweroff ;;
  *) back_to show_main_menu ;;
  esac
}

# ‚ĒÄ‚ĒÄ Main ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

show_main_menu() {
  go_to_menu "$(menu "Go" "ůįÄĽ  Apps\nůįßĎ  Learn\nůĪďě  Trigger\n  Style\n  Setup\nůįČČ  Install\nůį≠Ć  Remove\n  Update\nůįčĹ  About\n  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*)        walker ;;
  *learn*)       show_learn_menu ;;
  *trigger*)     show_trigger_menu ;;
  *share*)       show_share_menu ;;
  *background*)  theme-bg-next ;;
  *capture*)     show_capture_menu ;;
  *style*)       show_style_menu ;;
  *theme*)       theme-pick ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*)       show_setup_menu ;;
  *power*)       show_setup_power_menu ;;
  *install*)     show_install_menu ;;
  *remove*)      show_remove_menu ;;
  *update*)      show_update_menu ;;
  *about*)       float_terminal "fastfetch; read -n1" ;;
  *system*)      show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/menu/extensions.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

if [[ -n ${1:-} ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
